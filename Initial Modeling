library(dplyr)
library(lubridate)
library(stringr)

df_clean <- df_clean %>%
  # Extract stroke and distance from EVENT column
  mutate(
    DISTANCE = as.numeric(str_extract(EVENT, "^[0-9]+")),
    STROKE = str_extract(EVENT, "(?<=\\s).*(?=\\sSCY)"),
    
    # Season from swim date
    SWIM_DATE = as.Date(SWIM.DATE, format = "%m/%d/%Y"),
    SEASON = case_when(
      month(SWIM_DATE) >= 9 ~ year(SWIM_DATE),       # Sept onward = new season
      TRUE ~ year(SWIM_DATE) - 1
    ),
    
    # Player-season ID for random effect
    PLAYER_SEASON = paste(NAME, SEASON, sep = "_"),
    
    # Meet level proxy
    MEET_LEVEL = case_when(
      Spectator.Capacity >= 2000 ~ "Large",
      Spectator.Capacity >= 1500 ~ "Medium",
      TRUE ~ "Small"
    )
  )

