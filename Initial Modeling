```{r}

library(ggplot2)

# From pool fixed effects model, extract pool intercepts
pool_effects <- fixef(model_pool_fe)

# Pull only LOCATION coefficients
pool_df <- data.frame(
  LOCATION = names(pool_effects)[grepl("LOCATION", names(pool_effects))],
  effect = pool_effects[grepl("LOCATION", names(pool_effects))]
) %>%
  mutate(
    LOCATION = str_remove(LOCATION, "LOCATION"),
    # negative = faster
    direction = ifelse(effect < 0, "Faster", "Slower")
  ) %>%
  arrange(effect)

# Clean ranked dot plot
ggplot(pool_df, aes(x = effect, 
                    y = reorder(LOCATION, -effect),
                    color = direction)) +
  geom_point(size = 3) +
  geom_segment(aes(x = 0, xend = effect,
                   y = reorder(LOCATION, -effect),
                   yend = reorder(LOCATION, -effect)),
               linewidth = 0.8) +
  geom_vline(xintercept = 0, linetype = "dashed", color = "gray40") +
  scale_color_manual(values = c("Faster" = "steelblue", "Slower" = "tomato")) +
  labs(
    title = "Ranked Pool Effects on Swim Performance",
    subtitle = "Left of zero = faster pool, controlling for athlete and team quality",
    x = "Estimated Pool Effect (Z-score units)",
    y = "",
    color = ""
  ) +
  theme_minimal(base_size = 13) +
  theme(legend.position = "bottom")

