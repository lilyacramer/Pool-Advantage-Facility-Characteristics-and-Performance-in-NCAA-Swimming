```{r}
df_clean <- df_clean %>%
  group_by(EVENT) %>%
  mutate(SWIM_TIME_Z = as.numeric(scale(SWIM.TIME_SEC))) %>%
  ungroup()


library(lme4)
library(lmerTest)  # gives p-values

# Primary model:
# Fixed effects: pool characteristics + stroke + distance + meet level
# Random effects: team intercept + player-season intercept

model_primary <- lmer(
  SWIM_TIME_Z ~
    # Pool characteristics
    Depth..in. + Altitude..ft. + Lanes + Age..years. + Indoor +
    # Race controls
    STROKE + DISTANCE +
    # Meet level
    MEET_LEVEL +
    # Random effects: team quality + individual player-season form
    (1 | TEAM) + (1 | PLAYER_SEASON),
  data = df_clean,
  REML = TRUE
)

summary(model_primary)

```

```{r}
model_pool_fe <- lmer(
  SWIM_TIME_Z ~
    STROKE + DISTANCE + MEET_LEVEL +
    LOCATION +                          # pool fixed effects
    (1 | TEAM) + (1 | PLAYER_SEASON),
  data = df_clean,
  REML = FALSE                          # use ML for AIC comparison
)

# Refit primary with ML for fair AIC comparison
model_primary_ml <- lmer(
  SWIM_TIME_Z ~
    Depth..in. + Altitude..ft. + Lanes + Spectator.Capacity + Age..years. + Indoor +
    STROKE + DISTANCE + MEET_LEVEL +
    (1 | TEAM) + (1 | PLAYER_SEASON),
  data = df_clean,
  REML = FALSE
)

AIC(model_primary_ml, model_pool_fe)

