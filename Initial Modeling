```{r}
library(dplyr)
library(ggplot2)
library(tidyr)

# 1. Get top 10 fastest pools
top10_pools <- pool_df %>%
  slice(1:10) %>%
  pull(LOCATION)

# 2. Pull their characteristics and scale relative to all pools
# so colors are comparable across variables
top10_df <- df_clean %>%
  filter(LOCATION %in% top10_pools) %>%
  select(LOCATION, Depth..in., Altitude..ft., Lanes, Age..years., Indoor) %>%
  distinct() %>%
  # Join pool effect (speed ranking) for row ordering
  left_join(pool_df %>% select(LOCATION, effect), by = "LOCATION") %>%
  arrange(effect)   # fastest at top

# 3. Scale each characteristic across all pools (not just top 10)
# so you know if a value is high or low relative to average
all_pools_chars <- df_clean %>%
  select(LOCATION, Depth..in., Altitude..ft., Lanes, Age..years., Indoor) %>%
  distinct()

scaled_chars <- all_pools_chars %>%
  mutate(across(c(Depth..in., Altitude..ft., Lanes, Age..years., Indoor), scale))

top10_scaled <- scaled_chars %>%
  filter(LOCATION %in% top10_pools) %>%
  left_join(pool_df %>% select(LOCATION, effect), by = "LOCATION") %>%
  arrange(effect)

# 4. Pivot to long format for ggplot
heatmap_df <- top10_scaled %>%
  pivot_longer(
    cols = c(Depth..in., Altitude..ft., Lanes, Age..years., Indoor),
    names_to = "Characteristic",
    values_to = "Scaled_Value"
  ) %>%
  mutate(
    Characteristic = case_when(
      Characteristic == "Depth..in."    ~ "Pool Depth",
      Characteristic == "Altitude..ft." ~ "Altitude",
      Characteristic == "Lanes"         ~ "Number of Lanes",
      Characteristic == "Age..years."   ~ "Facility Age",
      Characteristic == "Indoor"        ~ "Indoor Pool",
      TRUE                              ~ Characteristic
    ),
    # Lock row order — fastest pool at top
    LOCATION = factor(LOCATION, levels = top10_scaled$LOCATION)
  )

# 5. Plot
ggplot(heatmap_df, aes(x = Characteristic, y = LOCATION, fill = Scaled_Value)) +
  geom_tile(color = "white", linewidth = 0.5) +
  geom_text(aes(label = round(Scaled_Value, 1)), size = 3.5, color = "gray20") +
  scale_fill_gradient2(
    low      = "steelblue",   # below average
    mid      = "white",
    high     = "tomato",      # above average
    midpoint = 0,
    name     = "Z-score\nvs. all pools"
  ) +
  labs(
    title    = "Top 10 Fastest Pools: Facility Characteristics",
    subtitle = "Pools ranked fastest (top) to slowest (bottom). Values scaled relative to all pools.",
    x        = NULL,
    y        = NULL
  ) +
  theme_minimal(base_size = 14) +
  theme(
    axis.text.x      = element_text(angle = 30, hjust = 1),
    panel.grid       = element_blank(),
    legend.position  = "right"
  )

