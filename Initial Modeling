```{r}
final_df$SWIM.TIME <- as.character(final_df$SWIM.TIME)
final_df$SWIM.TIME <- trimws(final_df$SWIM.TIME)

valid_rows <- grepl("^\\d+(:\\d+)?(\\.\\d+)?$", final_df$SWIM.TIME)

# Subset
df_clean <- final_df[valid_rows, ]

df_clean$SWIM.TIME_SEC <- sapply(df_clean$SWIM.TIME, function(x) {
  parts <- unlist(strsplit(x, ":"))
  parts <- as.numeric(parts)
  if(length(parts) == 2) {
    parts[1]*60 + parts[2]   # minutes:seconds
  } else if(length(parts) == 1) {
    parts[1]                 # seconds only
  } else {
    NA
  }
})

class(df_clean$SWIM.TIME_SEC) 

View(df_clean)

